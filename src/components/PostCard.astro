---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags: string[];
  category: string;
  featured?: boolean;
}

const { title, description, pubDate, slug, tags, category, featured = false } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const categoryColorMap: Record<string, string> = {
  AI:      'blue',
  EE:      'blue',
  Growth:  'green',
  Project: 'green',
  Other:   'gray',
};
const categoryColor = categoryColorMap[category] ?? 'gray';
---

<article class:list={['post-card', { 'post-card--featured': featured }]}>
  <a href={`/posts/${slug}`} class="post-card__link" tabindex="-1" aria-hidden="true"></a>
  <div class="post-card__meta">
    <span class={`badge badge--${categoryColor}`}>{category}</span>
    {featured && <span class="badge badge--green">精选</span>}
    <time datetime={pubDate.toISOString()} class="post-card__date">{formattedDate}</time>
  </div>
  <h2 class="post-card__title">
    <a href={`/posts/${slug}`}>{title}</a>
  </h2>
  <p class="post-card__desc">{description}</p>
  {tags.length > 0 && (
    <div class="post-card__tags">
      {tags.slice(0, 4).map(tag => (
        <span class="post-card__tag">#{tag}</span>
      ))}
    </div>
  )}
  <div class="post-card__footer">
    <a href={`/posts/${slug}`} class="post-card__read-more">
      阅读全文
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</article>

<style>
.post-card {
  position: relative;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
  transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
}
.post-card:hover {
  border-color: var(--green);
  box-shadow: var(--shadow-md);
  transform: translateY(-2px);
}

.post-card--featured {
  border-left: 4px solid var(--green);
}

.post-card__link {
  position: absolute;
  inset: 0;
  border-radius: var(--radius-lg);
}

.post-card__meta {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.post-card__date {
  font-size: 0.8rem;
  color: var(--text-3);
  margin-left: auto;
}

.post-card__title {
  font-size: 1.15rem;
  font-weight: 700;
  line-height: 1.4;
}
.post-card__title a {
  color: var(--text);
  text-decoration: none;
  position: relative;
  z-index: 1;
}
.post-card:hover .post-card__title a { color: var(--green-dark); }

.post-card__desc {
  font-size: 0.9rem;
  color: var(--text-2);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.post-card__tags {
  display: flex;
  gap: 0.4rem;
  flex-wrap: wrap;
}
.post-card__tag {
  font-size: 0.75rem;
  color: var(--text-3);
  transition: color 0.15s;
}
.post-card:hover .post-card__tag { color: var(--green); }

.post-card__footer {
  margin-top: auto;
  padding-top: 0.5rem;
}

.post-card__read-more {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--green-dark);
  position: relative;
  z-index: 1;
  text-decoration: none;
  transition: gap 0.2s;
}
.post-card:hover .post-card__read-more { gap: 0.55rem; }
</style>
