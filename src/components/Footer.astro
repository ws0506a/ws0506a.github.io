---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner container--wide">
    <div class="footer__brand">
      <span>⚡ AI成长引擎</span>
      <span class="footer__copy">© {year} changqingws. All rights reserved.</span>
    </div>
    <div class="footer__links">
      <a
        href="https://github.com/changqingws0506a"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="footer__icon-link"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
      </a>
      <a href="mailto:sunsetjhoney@gmail.com" class="footer__icon-link" aria-label="邮件联系">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
      </a>
    </div>
  </div>
  <div class="footer__bottom">
    <span>Built with <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> · Powered by ☕ & 🧠</span>
  </div>
</footer>

<style>
.footer {
  margin-top: 5rem;
  border-top: 1px solid var(--border);
  background: var(--bg-2);
}

.footer__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  padding-top: 1.5rem;
  padding-bottom: 0.75rem;
}

.footer__brand {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  font-weight: 600;
  font-size: 0.95rem;
  color: var(--text);
}

.footer__copy {
  font-size: 0.8rem;
  font-weight: 400;
  color: var(--text-3);
}

.footer__links {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.footer__icon-link {
  display: flex;
  align-items: center;
  padding: 0.4rem;
  border-radius: var(--radius-sm);
  color: var(--text-3);
  transition: all 0.15s;
}
.footer__icon-link:hover {
  color: var(--green-dark);
  background: color-mix(in srgb, var(--green) 8%, transparent);
}

.footer__bottom {
  text-align: center;
  padding: 0.75rem 1.25rem 1.25rem;
  font-size: 0.8rem;
  color: var(--text-3);
}
.footer__bottom a { color: var(--green-dark); }

@media (max-width: 480px) {
  .footer__inner { flex-direction: column; align-items: flex-start; }
}
</style>
