---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner container">
    <p class="footer__text">
      © {year} 晨思 · Built with <a href="https://astro.build" target="_blank" rel="noopener">Astro</a>
      · Hosted on <a href="https://pages.github.com" target="_blank" rel="noopener">GitHub Pages</a>
    </p>
  </div>
</footer>

<style>
.footer {
  margin-top: 6rem;
  border-top: 1px solid var(--border);
  padding: 2rem 0;
}
.footer__text {
  text-align: center;
  font-size: 0.8rem;
  color: var(--text-3);
}
.footer__text a { color: var(--text-3); }
.footer__text a:hover { color: var(--green); }
</style>
