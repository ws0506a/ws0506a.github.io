---
const navLinks = [
  { href: '/',            label: '首页' },
  { href: '/posts',       label: '文章' },
  { href: '/categories',  label: '分类' },
  { href: '/tags',        label: '标签' },
  { href: 'https://github.com/ws0506a', label: 'GitHub', external: true },
];

const pathname = Astro.url.pathname;
---

<header class="header">
  <div class="header__inner container--wide">
    <a href="/" class="header__logo">晨思</a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-hidden="true" />
    <label for="nav-toggle" class="nav-hamburger" aria-label="菜单">
      <span></span><span></span><span></span>
    </label>

    <nav class="header__nav" aria-label="主导航">
      {navLinks.map(({ href, label, external }) => {
        const isActive = !external && (href === '/' ? pathname === '/' : pathname.startsWith(href));
        return (
          <a
            href={href}
            class:list={['header__nav-link', { 'header__nav-link--active': isActive }]}
            target={external ? '_blank' : undefined}
            rel={external ? 'noopener noreferrer' : undefined}
            aria-current={isActive ? 'page' : undefined}
          >
            {label}
          </a>
        );
      })}
    </nav>
  </div>
</header>

<style>
.header {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 50;
  background: rgba(13, 17, 23, 0.85);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
}

.header__inner {
  display: flex;
  align-items: center;
  height: 3.5rem;
  gap: 1.5rem;
}

.header__logo {
  font-weight: 700;
  font-size: 1.1rem;
  color: var(--text);
  text-decoration: none;
  flex-shrink: 0;
  letter-spacing: 0.05em;
}
.header__logo:hover { color: var(--green); }

.header__nav {
  display: flex;
  align-items: center;
  gap: 0.1rem;
  margin-left: auto;
}

.header__nav-link {
  padding: 0.35rem 0.75rem;
  border-radius: var(--radius-md);
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--text-2);
  text-decoration: none;
  transition: all 0.15s;
}
.header__nav-link:hover { color: var(--text); background: var(--bg-3); }
.header__nav-link--active { color: var(--green); }

.nav-toggle { display: none; }
.nav-hamburger { display: none; }

@media (max-width: 580px) {
  .nav-hamburger {
    display: flex; flex-direction: column; gap: 5px;
    cursor: pointer; margin-left: auto; padding: 0.5rem;
  }
  .nav-hamburger span {
    display: block; width: 20px; height: 2px;
    background: var(--text-2); border-radius: 2px; transition: all 0.25s;
  }
  .header__nav {
    display: none; position: fixed;
    top: 3.5rem; left: 0; right: 0;
    flex-direction: column; gap: 0;
    background: var(--bg-2);
    border-bottom: 1px solid var(--border);
    padding: 0.5rem;
    margin-left: 0;
  }
  .nav-toggle:checked ~ nav { display: flex; }
  .nav-toggle:checked + label span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-toggle:checked + label span:nth-child(2) { opacity: 0; }
  .nav-toggle:checked + label span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
}
</style>
