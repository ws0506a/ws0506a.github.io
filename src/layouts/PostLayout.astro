---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, tags, category, math } = post.data;

const formattedPubDate = pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric', month: 'long', day: 'numeric',
});
const formattedUpdatedDate = updatedDate?.toLocaleDateString('zh-CN', {
  year: 'numeric', month: 'long', day: 'numeric',
});

const readingTime = Math.ceil((post.body?.length ?? 1000) / 400);
---

<BaseLayout title={title} description={description} math={math}>
  <div class="post-page">
    <div class="container">
      <!-- Breadcrumb -->
      <nav class="breadcrumb" aria-label="面包屑">
        <a href="/">首页</a>
        <span aria-hidden="true">›</span>
        <a href="/posts">文章</a>
        <span aria-hidden="true">›</span>
        <span>{title}</span>
      </nav>

      <!-- Post Header -->
      <header class="post-header">
        <div class="post-header__meta">
          <span class="badge badge--blue">{category}</span>
          <time datetime={pubDate.toISOString()} class="post-header__date">{formattedPubDate}</time>
          <span class="post-header__read-time">约 {readingTime} 分钟</span>
        </div>
        <h1 class="post-header__title">{title}</h1>
        <p class="post-header__desc">{description}</p>
        {tags.length > 0 && (
          <div class="post-header__tags">
            {tags.map(tag => <span class="badge badge--gray">#{tag}</span>)}
          </div>
        )}
        {updatedDate && (
          <p class="post-header__updated">
            最近更新：{formattedUpdatedDate}
          </p>
        )}
      </header>

      <hr class="post-divider" />

      <!-- Post Body -->
      <div class="prose">
        <slot />
      </div>

      <!-- Post Footer -->
      <footer class="post-footer">
        <a href="/posts" class="post-footer__back">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
          返回文章列表
        </a>
      </footer>
    </div>
  </div>
</BaseLayout>

<style>
.post-page {
  padding: 2rem 0 4rem;
}

.breadcrumb {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.8rem;
  color: var(--text-3);
  margin-bottom: 2rem;
}
.breadcrumb a { color: var(--text-3); }
.breadcrumb a:hover { color: var(--green-dark); }
.breadcrumb span:last-child {
  color: var(--text-2);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 200px;
}

.post-header { margin-bottom: 2rem; }

.post-header__meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-wrap: wrap;
  margin-bottom: 1rem;
}

.post-header__date,
.post-header__read-time {
  font-size: 0.85rem;
  color: var(--text-3);
}

.post-header__title {
  font-size: 2rem;
  font-weight: 800;
  line-height: 1.3;
  color: var(--text);
  margin-bottom: 0.75rem;
}

.post-header__desc {
  font-size: 1.05rem;
  color: var(--text-2);
  line-height: 1.65;
  margin-bottom: 1rem;
}

.post-header__tags {
  display: flex;
  gap: 0.4rem;
  flex-wrap: wrap;
}

.post-header__updated {
  margin-top: 0.75rem;
  font-size: 0.8rem;
  color: var(--text-3);
}

.post-divider {
  border: none;
  border-top: 2px solid var(--border);
  margin: 2rem 0;
}

.post-footer {
  margin-top: 3rem;
  padding-top: 2rem;
  border-top: 1px solid var(--border);
}

.post-footer__back {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--green-dark);
  transition: gap 0.2s;
}
.post-footer__back:hover { gap: 0.65rem; }

@media (max-width: 640px) {
  .post-header__title { font-size: 1.5rem; }
}
</style>
