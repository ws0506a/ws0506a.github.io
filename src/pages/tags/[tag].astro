---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const allPosts = await getCollection('posts', ({ data }) => !data.draft);
  const tags = [...new Set(allPosts.flatMap(p => p.data.tags))];
  return tags.map(tag => ({
    params: { tag },
    props: {
      posts: allPosts
        .filter(p => p.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
};

const { tag } = Astro.params;
const { posts } = Astro.props;

const categoryColors: Record<string, string> = {
  AI: 'blue', EE: 'blue', Growth: 'green', Project: 'green', Other: 'gray',
};
---

<BaseLayout title={`#${tag}`} description={`标签「${tag}」下的所有文章`}>
  <div class="page">
    <div class="container">
      <header class="page-header">
        <a href="/tags" class="back-link">← 所有标签</a>
        <h1 class="page-header__title">#{tag}</h1>
        <p class="page-header__sub">{posts.length} 篇文章</p>
      </header>

      <ul class="post-list">
        {posts.map(post => (
          <li class="post-item">
            <div class="post-item__left">
              <span class={`badge badge--${categoryColors[post.data.category] ?? 'gray'}`}>
                {post.data.category}
              </span>
              <div>
                <a href={`/posts/${post.id}`} class="post-item__title">{post.data.title}</a>
                <p class="post-item__desc">{post.data.description}</p>
              </div>
            </div>
            <time datetime={post.data.pubDate.toISOString()} class="post-item__date">
              {post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' })}
            </time>
          </li>
        ))}
      </ul>
    </div>
  </div>
</BaseLayout>

<style>
.page { padding: 5rem 0 4rem; }

.back-link { font-size: 0.85rem; color: var(--text-3); display: block; margin-bottom: 0.75rem; }
.back-link:hover { color: var(--green); }

.page-header { margin-bottom: 2.5rem; }
.page-header__title { font-size: 1.75rem; font-weight: 800; color: var(--text); margin-bottom: 0.25rem; }
.page-header__sub { font-size: 0.875rem; color: var(--text-3); }

.post-list { list-style: none; }

.post-item {
  display: flex; align-items: flex-start;
  justify-content: space-between; gap: 1rem;
  padding: 1.1rem 0; border-bottom: 1px solid var(--border);
}
.post-item:last-child { border-bottom: none; }

.post-item__left { display: flex; gap: 0.75rem; align-items: flex-start; min-width: 0; flex: 1; }

.post-item__title {
  display: block; font-size: 0.95rem; font-weight: 600;
  color: var(--text); text-decoration: none; transition: color 0.15s;
}
.post-item__title:hover { color: var(--green); }

.post-item__desc {
  font-size: 0.8rem; color: var(--text-3); margin-top: 0.2rem;
  line-height: 1.5;
  display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden;
}

.post-item__date {
  font-size: 0.78rem; color: var(--text-3);
  white-space: nowrap; flex-shrink: 0; font-variant-numeric: tabular-nums;
  padding-top: 0.15rem;
}
</style>
