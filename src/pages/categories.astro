---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);

const categoryMap = new Map<string, typeof allPosts>();
for (const post of allPosts) {
  const cat = post.data.category;
  if (!categoryMap.has(cat)) categoryMap.set(cat, []);
  categoryMap.get(cat)!.push(post);
}

const categoryOrder = ['AI', 'EE', 'Growth', 'Project', 'Other'];
const categories = categoryOrder
  .filter(c => categoryMap.has(c))
  .map(c => ({ name: c, posts: categoryMap.get(c)!.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()) }));

const colorMap: Record<string, string> = {
  AI: 'blue', EE: 'blue', Growth: 'green', Project: 'green', Other: 'gray',
};

const labelMap: Record<string, string> = {
  AI: 'AI · 人工智能',
  EE: 'EE · 电子工程',
  Growth: 'Growth · 成长',
  Project: 'Project · 项目',
  Other: 'Other · 其他',
};
---

<BaseLayout title="分类" description="按分类浏览全部文章">
  <div class="page">
    <div class="container">
      <header class="page-header">
        <h1 class="page-header__title">分类</h1>
        <p class="page-header__sub">共 {allPosts.length} 篇文章 · {categories.length} 个分类</p>
      </header>

      {categories.map(({ name, posts }) => (
        <section class="cat-section">
          <div class="cat-section__header">
            <span class={`badge badge--${colorMap[name]}`}>{labelMap[name]}</span>
            <span class="cat-section__count">{posts.length} 篇</span>
          </div>
          <ul class="post-list">
            {posts.map(post => (
              <li class="post-item">
                <a href={`/posts/${post.id}`} class="post-item__title">{post.data.title}</a>
                <time datetime={post.data.pubDate.toISOString()} class="post-item__date">
                  {post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' })}
                </time>
              </li>
            ))}
          </ul>
        </section>
      ))}

      {categories.length === 0 && (
        <p class="empty">暂无文章，敬请期待 🚀</p>
      )}
    </div>
  </div>
</BaseLayout>

<style>
.page { padding: 5rem 0 4rem; }

.page-header { margin-bottom: 3rem; }
.page-header__title { font-size: 1.75rem; font-weight: 800; color: var(--text); margin-bottom: 0.35rem; }
.page-header__sub { font-size: 0.875rem; color: var(--text-3); }

.cat-section { margin-bottom: 2.5rem; }

.cat-section__header {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--border);
}
.cat-section__count { font-size: 0.8rem; color: var(--text-3); }

.post-list { list-style: none; }

.post-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  padding: 0.7rem 0;
  border-bottom: 1px solid rgba(48, 54, 61, 0.5);
}
.post-item:last-child { border-bottom: none; }

.post-item__title {
  font-size: 0.9rem;
  color: var(--text-2);
  text-decoration: none;
  transition: color 0.15s;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.post-item__title:hover { color: var(--green); }

.post-item__date {
  font-size: 0.78rem;
  color: var(--text-3);
  white-space: nowrap;
  flex-shrink: 0;
  font-variant-numeric: tabular-nums;
}

.empty { color: var(--text-3); padding: 2rem 0; }
</style>
