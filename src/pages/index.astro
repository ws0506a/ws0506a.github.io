---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const totalPosts = allPosts.length;
const allTags = [...new Set(allPosts.flatMap(p => p.data.tags))];
const allCategories = [...new Set(allPosts.map(p => p.data.category))];

const categoryColors: Record<string, string> = {
  AI: 'blue', EE: 'blue', Growth: 'green', Project: 'green', Other: 'gray',
};
---

<BaseLayout title="首页">

  <!-- ===== 全屏星空 Hero ===== -->
  <section class="hero">
    <canvas id="starfield" class="starfield" aria-hidden="true"></canvas>

    <!-- 星云光晕 -->
    <div class="nebula nebula--1" aria-hidden="true"></div>
    <div class="nebula nebula--2" aria-hidden="true"></div>
    <div class="nebula nebula--3" aria-hidden="true"></div>

    <div class="hero__content">
      <div class="hero__avatar" aria-hidden="true">🎖️</div>
      <h1 class="hero__title">
        你好，我是 <span class="hero__name-accent">晨思</span>
      </h1>
      <p class="hero__sub">
        退伍老兵 · 电子信息工程 · AI 开发者
      </p>
      <p class="hero__desc">
        用系统化思维构建 AI 时代的个人竞争力<br />
        这里记录我的学习、项目与成长
      </p>
      <div class="hero__cta">
        <a href="/posts" class="btn-primary">阅读文章</a>
        <a href="/projects" class="btn-ghost">查看项目</a>
      </div>
    </div>

    <!-- 滚动提示 -->
    <div class="scroll-hint" aria-hidden="true">
      <span class="scroll-hint__line"></span>
      <span class="scroll-hint__text">向下滚动</span>
    </div>
  </section>

  <!-- ===== 统计条 ===== -->
  <div class="stats-bar">
    <div class="container--wide">
      <div class="stats-bar__inner">
        <a href="/posts" class="stat">
          <span class="stat__num">{totalPosts}</span>
          <span class="stat__label">篇文章</span>
        </a>
        <div class="stat-sep"></div>
        <a href="/categories" class="stat">
          <span class="stat__num">{allCategories.length}</span>
          <span class="stat__label">个分类</span>
        </a>
        <div class="stat-sep"></div>
        <a href="/tags" class="stat">
          <span class="stat__num">{allTags.length}</span>
          <span class="stat__label">个标签</span>
        </a>
        <div class="stat-sep"></div>
        <div class="stat">
          <span class="stat__num">429</span>
          <span class="stat__label">次反思</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== 最新文章 ===== -->
  <section class="section">
    <div class="container">
      <div class="sec-header">
        <h2 class="sec-title">最新文章</h2>
        <a href="/posts" class="sec-more">全部 →</a>
      </div>
      <div class="posts-grid">
        {recentPosts.map(post => (
          <a href={`/posts/${post.id}`} class="post-card">
            <div class="post-card__top">
              <span class={`badge badge--${categoryColors[post.data.category] ?? 'gray'}`}>
                {post.data.category}
              </span>
              <time class="post-card__date" datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('zh-CN', { month: '2-digit', day: '2-digit' })}
              </time>
            </div>
            <h3 class="post-card__title">{post.data.title}</h3>
            <p class="post-card__desc">{post.data.description}</p>
            <div class="post-card__arrow">阅读 →</div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<!-- 星空 canvas 脚本 -->
<script>
const canvas = document.getElementById('starfield') as HTMLCanvasElement;
if (canvas) {
  const ctx = canvas.getContext('2d')!;
  let stars: { x: number; y: number; r: number; o: number; speed: number }[] = [];

  function resize() {
    canvas.width  = window.innerWidth;
    canvas.height = window.innerHeight;
  }

  function initStars() {
    stars = [];
    const count = Math.floor((canvas.width * canvas.height) / 3000);
    for (let i = 0; i < count; i++) {
      stars.push({
        x:     Math.random() * canvas.width,
        y:     Math.random() * canvas.height,
        r:     Math.random() * 1.4 + 0.2,
        o:     Math.random() * 0.8 + 0.2,
        speed: Math.random() * 0.008 + 0.002,
      });
    }
  }

  let frame = 0;
  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    frame += 0.01;
    for (const s of stars) {
      const opacity = s.o * (0.6 + 0.4 * Math.sin(frame * s.speed * 100));
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);

      // 亮星加十字光芒
      if (s.r > 1.2) {
        ctx.shadowBlur = 8;
        ctx.shadowColor = `rgba(200,220,255,${opacity * 0.8})`;
      } else {
        ctx.shadowBlur = 3;
        ctx.shadowColor = `rgba(200,220,255,${opacity * 0.4})`;
      }
      ctx.fillStyle = `rgba(210,225,255,${opacity})`;
      ctx.fill();
      ctx.shadowBlur = 0;
    }
    requestAnimationFrame(draw);
  }

  resize();
  initStars();
  draw();
  window.addEventListener('resize', () => { resize(); initStars(); });
}
</script>

<style>
/* ===== Hero ===== */
.hero {
  position: relative;
  width: 100%; height: 100vh;
  display: flex; align-items: center; justify-content: center;
  overflow: hidden; background: #000;
}

.starfield {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  pointer-events: none;
}

/* 星云光晕 */
.nebula {
  position: absolute; border-radius: 50%;
  filter: blur(80px); pointer-events: none;
}
.nebula--1 {
  width: 600px; height: 400px;
  top: 10%; left: 15%;
  background: radial-gradient(ellipse, rgba(124,58,237,0.18) 0%, transparent 70%);
}
.nebula--2 {
  width: 500px; height: 350px;
  bottom: 15%; right: 10%;
  background: radial-gradient(ellipse, rgba(34,197,94,0.12) 0%, transparent 70%);
}
.nebula--3 {
  width: 400px; height: 300px;
  top: 40%; left: 50%;
  transform: translateX(-50%);
  background: radial-gradient(ellipse, rgba(96,165,250,0.08) 0%, transparent 70%);
}

.hero__content {
  position: relative; z-index: 2;
  display: flex; flex-direction: column; align-items: center;
  text-align: center; gap: 1rem; padding: 2rem 1.5rem;
}

.hero__avatar { font-size: 4rem; line-height: 1; margin-bottom: 0.5rem; }

.hero__title {
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 800; letter-spacing: -0.02em;
  color: var(--text); line-height: 1.15;
}

.hero__name-accent {
  background: linear-gradient(135deg, #4ade80 0%, #60a5fa 50%, #a78bfa 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero__sub {
  font-size: 0.95rem; color: var(--text-3);
  letter-spacing: 0.05em;
}

.hero__desc {
  font-size: 1rem; color: var(--text-2);
  line-height: 1.8; max-width: 420px;
}

.hero__cta { display: flex; gap: 0.75rem; flex-wrap: wrap; justify-content: center; margin-top: 0.5rem; }

.btn-primary {
  padding: 0.6rem 1.5rem; border-radius: var(--radius-md);
  font-size: 0.875rem; font-weight: 600;
  background: var(--text); color: var(--bg);
  transition: opacity 0.2s, transform 0.2s;
}
.btn-primary:hover { opacity: 0.88; transform: translateY(-1px); }

.btn-ghost {
  padding: 0.6rem 1.5rem; border-radius: var(--radius-md);
  font-size: 0.875rem; font-weight: 600;
  border: 1px solid var(--border-2); color: var(--text-2);
  transition: border-color 0.2s, color 0.2s;
}
.btn-ghost:hover { border-color: var(--text-3); color: var(--text); }

/* 滚动提示 */
.scroll-hint {
  position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
}
.scroll-hint__line {
  display: block; width: 1px; height: 40px;
  background: linear-gradient(to bottom, transparent, var(--text-3));
  animation: drop 1.8s ease-in-out infinite;
}
.scroll-hint__text { font-size: 0.65rem; color: var(--text-3); letter-spacing: 0.15em; text-transform: uppercase; }
@keyframes drop { 0%,100%{opacity:0; transform:scaleY(0); transform-origin:top;} 50%{opacity:1; transform:scaleY(1);} }

/* ===== Stats Bar ===== */
.stats-bar {
  background: var(--bg-2);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}
.stats-bar__inner {
  display: flex; align-items: center;
  justify-content: center; flex-wrap: wrap;
  padding: 1.25rem 0;
}
.stat {
  display: flex; flex-direction: column; align-items: center;
  padding: 0.25rem 2.5rem; gap: 0.15rem;
  text-decoration: none; transition: opacity 0.15s;
}
a.stat:hover { opacity: 0.75; }
.stat__num { font-size: 1.6rem; font-weight: 800; color: var(--text); line-height: 1; }
.stat__label { font-size: 0.7rem; color: var(--text-3); letter-spacing: 0.08em; }
.stat-sep { width: 1px; height: 2rem; background: var(--border); }

/* ===== Section ===== */
.section { padding: 5rem 0; }

.sec-header { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 2rem; }
.sec-title { font-size: 0.7rem; font-weight: 700; color: var(--text-3); letter-spacing: 0.15em; text-transform: uppercase; }
.sec-more { font-size: 0.8rem; color: var(--text-3); transition: color 0.15s; }
.sec-more:hover { color: var(--text); }

/* ===== Post Cards — Linear style ===== */
.posts-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 1px;
  background: var(--border);
  border: 1px solid var(--border);
  border-radius: var(--radius-xl);
  overflow: hidden;
}

.post-card {
  display: flex; flex-direction: column; gap: 0.6rem;
  padding: 1.5rem; background: var(--bg-2);
  transition: background 0.15s;
  text-decoration: none;
}
.post-card:hover { background: var(--bg-3); }

.post-card__top { display: flex; align-items: center; justify-content: space-between; }
.post-card__date { font-size: 0.72rem; color: var(--text-3); font-variant-numeric: tabular-nums; }

.post-card__title { font-size: 0.95rem; font-weight: 700; color: var(--text); line-height: 1.45; }
.post-card__desc {
  font-size: 0.8rem; color: var(--text-3); line-height: 1.6; flex: 1;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}
.post-card__arrow { font-size: 0.75rem; color: var(--text-3); margin-top: 0.5rem; transition: color 0.15s; }
.post-card:hover .post-card__arrow { color: var(--green); }

@media (max-width: 600px) {
  .stat { padding: 0.25rem 1.5rem; }
  .posts-grid { grid-template-columns: 1fr; }
}
</style>
