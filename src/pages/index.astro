---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featuredPosts = sortedPosts.filter(p => p.data.featured);
const recentPosts   = sortedPosts.slice(0, 6);
---

<BaseLayout
  title="首页"
  description="AI成长引擎 — 退伍大学生 × AI × 成长系统，分享 AI 开发、电子工程与个人成长"
>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero__badge">
        <span class="badge badge--green">🎖️ 退伍老兵</span>
        <span class="badge badge--blue">🤖 AI 开发者</span>
        <span class="badge badge--green">📈 成长系统</span>
      </div>
      <h1 class="hero__title">
        AI<span class="hero__title-accent">成长</span>引擎
      </h1>
      <p class="hero__subtitle">
        退伍大学生 × 电子信息工程 × AI 自学之路<br />
        用系统化思维，构建 AI 时代的个人竞争力
      </p>
      <div class="hero__actions">
        <a href="/posts" class="btn btn--primary">浏览全部文章</a>
        <a href="/about" class="btn btn--outline">了解我</a>
      </div>
      <div class="hero__stats">
        <div class="hero__stat">
          <span class="hero__stat-num" style="color: var(--green)">280+</span>
          <span class="hero__stat-label">日课天数</span>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <span class="hero__stat-num" style="color: var(--blue)">429</span>
          <span class="hero__stat-label">反思次数</span>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <span class="hero__stat-num" style="color: var(--green)">230+</span>
          <span class="hero__stat-label">公众号文章</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Posts -->
  {featuredPosts.length > 0 && (
    <section class="section">
      <div class="container">
        <h2 class="section__title">
          <span class="section__title-accent">⭐</span> 精选文章
        </h2>
        <div class="posts-grid">
          {featuredPosts.map(post => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              slug={post.id}
              tags={post.data.tags}
              category={post.data.category}
              featured={true}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Recent Posts -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2 class="section__title">
          <span class="section__title-accent">📝</span> 最新文章
        </h2>
        <a href="/posts" class="section__more">查看全部 →</a>
      </div>
      {recentPosts.length === 0 ? (
        <div class="empty-state">
          <p>文章正在路上，敬请期待 🚀</p>
        </div>
      ) : (
        <div class="posts-grid">
          {recentPosts.map(post => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              slug={post.id}
              tags={post.data.tags}
              category={post.data.category}
            />
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
/* ===== Hero ===== */
.hero {
  padding: 5rem 0 4rem;
  text-align: center;
  background: linear-gradient(
    180deg,
    color-mix(in srgb, var(--green) 4%, var(--bg)) 0%,
    var(--bg) 100%
  );
  border-bottom: 1px solid var(--border);
}

.hero__badge {
  display: flex;
  justify-content: center;
  gap: 0.5rem;
  flex-wrap: wrap;
  margin-bottom: 1.5rem;
}

.hero__title {
  font-size: clamp(2.5rem, 6vw, 4rem);
  font-weight: 900;
  line-height: 1.15;
  color: var(--text);
  letter-spacing: -0.02em;
  margin-bottom: 1rem;
}

.hero__title-accent {
  background: linear-gradient(135deg, var(--green), var(--blue));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero__subtitle {
  font-size: 1.05rem;
  color: var(--text-2);
  line-height: 1.75;
  max-width: 500px;
  margin: 0 auto 2rem;
}

.hero__actions {
  display: flex;
  justify-content: center;
  gap: 0.75rem;
  flex-wrap: wrap;
  margin-bottom: 3rem;
}

.btn {
  display: inline-flex;
  align-items: center;
  padding: 0.65rem 1.5rem;
  border-radius: var(--radius-md);
  font-size: 0.95rem;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.2s;
  border: 2px solid transparent;
}
.btn--primary {
  background: linear-gradient(135deg, var(--green), var(--green-dark));
  color: white;
  box-shadow: 0 2px 8px color-mix(in srgb, var(--green) 35%, transparent);
}
.btn--primary:hover {
  transform: translateY(-1px);
  box-shadow: 0 4px 14px color-mix(in srgb, var(--green) 40%, transparent);
  color: white;
}
.btn--outline {
  border-color: var(--border-2);
  color: var(--text-2);
  background: var(--bg);
}
.btn--outline:hover {
  border-color: var(--blue);
  color: var(--blue-dark);
}

.hero__stats {
  display: inline-flex;
  align-items: center;
  gap: 2rem;
  background: var(--bg-2);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 1rem 2rem;
}
.hero__stat { text-align: center; }
.hero__stat-num {
  display: block;
  font-size: 1.75rem;
  font-weight: 800;
  line-height: 1;
}
.hero__stat-label {
  font-size: 0.75rem;
  color: var(--text-3);
  margin-top: 0.2rem;
}
.hero__stat-divider {
  width: 1px;
  height: 2.5rem;
  background: var(--border);
}

/* ===== Sections ===== */
.section { padding: 3.5rem 0; }
.section + .section { border-top: 1px solid var(--border); }

.section__header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 1.5rem;
}

.section__title {
  font-size: 1.35rem;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 1.5rem;
}
.section__header .section__title { margin-bottom: 0; }

.section__title-accent { margin-right: 0.25rem; }

.section__more {
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--green-dark);
}

.posts-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 1.25rem;
}

.empty-state {
  text-align: center;
  padding: 3rem;
  color: var(--text-3);
  background: var(--bg-2);
  border: 1px dashed var(--border);
  border-radius: var(--radius-lg);
}

@media (max-width: 600px) {
  .hero { padding: 3rem 0 2.5rem; }
  .hero__stats { gap: 1.25rem; padding: 0.75rem 1.25rem; }
  .hero__stat-num { font-size: 1.4rem; }
  .posts-grid { grid-template-columns: 1fr; }
}
</style>
